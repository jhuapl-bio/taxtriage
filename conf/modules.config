/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

// Wrap in a single closure so task.attempt is resolved at runtime (required for NF v25+).
process {
    withName: KRAKEN2_KRAKEN2 {
        memory   = { params.force_mem ? params.force_mem as nextflow.util.MemoryUnit : 36.GB * task.attempt * 2 } // Starts with 36 GB and doubles each attempt
        ext.args = params.low_memory ? ' --memory-mapping ' : ''
    }
}



process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]
    withName:CENTRIFUGE_CENTRIFUGE {
        errorStrategy  = 'ignore'
    }

    withName:MULTIQC {
        ext {
            args = ''
        }
        errorStrategy  = 'ignore'
        publishDir = [path:{ "${params.outdir}/report" }, mode:'copy', saveAs:{ filename -> filename.equals('versions.yml') ? null : filename }]
    }
    withName: MMSEQS_EASYCLUSTER {
        errorStrategy  = 'ignore'
    }
    withName: MMSEQS_TAXONOMY {
        // --split-memory-limit / --split are now derived from task.memory inside the module
        // (70% of the allocation, auto split count). Don't hardcode them here or you risk an
        // OOM when the fixed limit exceeds the actual RAM (e.g. 8G limit on a 7G box).
        //
        // Speed-tuned: approximate 2bLCA (--lca-mode 2), lower sensitivity (-s 2.0) and a
        // capped prefilter (--max-seqs 100). Queries are already deduped by linclust upstream.
        ext.args = '--lca-mode 2 --tax-lineage 1 -s 2.0 --max-seqs 100'
        publishDir = [
            path: { "${params.outdir}/novelty/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    // PYRODIGAL: default gene-prediction pre-step for novelty (skip with --disable_gene). Predicts
    // ORFs on the contigs; the .fna CDS become the per-query unit for the chosen backend. -p meta =
    // metagenome mode (no training set, correct for mixed/assembled contigs).
    withName: PYRODIGAL {
        errorStrategy = 'ignore'
        ext.args      = '-p meta'
        publishDir = [
            path: { "${params.outdir}/novelty/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    // --- Alternative novelty backends (selected via --novelty) -----------------------------
    // KAIJU: greedy translated search on the de novo contigs (no Pyrodigal / no protein dedup).
    withName: KAIJU {
        errorStrategy = 'ignore'
        // Run mode is switchable via --novelty_kaiju_mode (greedy|mem). greedy allows up to 5
        // substitutions (-e 5) and picks a nearest-neighbour even on divergent contigs; mem uses
        // exact maximum-exact-matches only, which avoids ties collapsing long conserved contigs
        // up to the genus LCA. -e is greedy-only, so it is omitted in mem mode.
        ext.args      = ( (params.novelty_kaiju_mode ?: 'greedy').toString().toLowerCase() == 'mem' ) ? '-a mem' : '-a greedy -e 5'
        publishDir = [
            path: { "${params.outdir}/novelty/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    // BRACKEN backend: Kraken2 over the contigs, then bracken abundance re-estimation.
    withName: KRAKEN2_NOVELTY {
        errorStrategy = 'ignore'
        publishDir = [
            path: { "${params.outdir}/novelty/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*report.txt',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: BRACKEN {
        errorStrategy = 'ignore'
        publishDir = [
            path: { "${params.outdir}/novelty/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: NOVELTY_SCORE {
        publishDir = [
            path: { "${params.outdir}/novelty" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: SAMPLESHEET_CHECK {
        publishDir = [
            path: { "${params.outdir}/pipeline_info" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: BCFTOOLS_MPILEUP{
        ext.args2 = ' -c '
        errorStrategy  = 'ignore'
    }

    withName: MERGE_ALIGNMENT_MERGES {
        errorStrategy  = 'ignore'
    }


    withName: MERGE_FASTA{
        errorStrategy = {
            task.exitStatus in [1,143,137,104,134,139] ? 'retry' : task.exitStatus in [255] ? 'ignore' : 'finish'
        }
    }

    withName: FASTQC{
        errorStrategy  = 'ignore'
        ext.args = '--quiet'
    }
    withName: NANOPLOT{
        errorStrategy  = 'ignore'
    }
    withName: BCFTOOLS_STATS {
        errorStrategy = {
            task.exitStatus in [1,143,137,104,134,139] ? 'retry' : task.exitStatus in [255] ? 'ignore' : 'finish'
        }
    }
    withName: SAMTOOLS_VIEW{
        ext.prefix = { "${meta.id}.remove" }
    }
    withName: SAMTOOLS_INDEX {
        ext.args = ' -c '
        publishDir = [path:{ "${params.outdir}/alignment" }, mode:'copy', saveAs:{ filename -> filename.equals('versions.yml') ? null : filename }]
    }
    withName: SAMTOOLS_MERGE {
        publishDir = [path:{ "${params.outdir}/alignment" }, mode:'copy', saveAs:{ filename -> filename.equals('versions.yml') ? null : filename }]
    }

    withName: BCFTOOLS_CONSENSUS{
        errorStrategy = 'ignore'
        ext.prefix = { "${meta.id}.consensus" }
    }
    withName: ALIGNMENT_PER_SAMPLE {
        errorStrategy = {
            if( task.exitStatus in [143, 137, 104, 134, 139, 1] ) {
                task.attempt <= 2 ? 'retry' : 'ignore'
            }
            else {
                'ignore'
            }
        }
        memory = { 72.GB * task.attempt * 2 }
        maxRetries = 2
    }
    withName: ALIGNMENT_PER_SAMPLE_CONTROLS {
        errorStrategy = 'ignore'
    }
    withName: COMBINE_SAMPLES_JSON {
        errorStrategy = 'ignore'
    }
    withName: MEGAHIT {
        errorStrategy =  {
            if( task.exitStatus in [143, 137, 104, 134, 139, 1] ) {
                task.attempt <= 2 ? 'retry' : 'ignore'
            }
            else {
                'ignore'
            }
        }
        memory = { 72.GB * task.attempt * 2 }
        maxRetries = 2
        ext.args = ''
    }
    withName: KRONA_KTIMPORTTEXT {
        errorStrategy  = 'ignore'
        publishDir = [path:{ "${params.outdir}/report" }, mode:'copy', saveAs:{ filename -> filename.equals('versions.yml') ? null : filename }]
    }

    withName: MEGAHIT_LONG {
        errorStrategy = {
            if( task.exitStatus in [143, 137, 104, 134, 139, 1] ) {
                task.attempt <= 2 ? 'retry' : 'ignore'
            }
            else {
                'ignore'
            }
        }
        memory = { 72.GB * task.attempt * 2 }
        maxRetries = 2
    }
    withName: FEATURES_MAP {
        errorStrategy = 'ignore'
    }
    withName: DIAMOND_MAKEDB {
        errorStrategy = 'ignore'
    }
    withName: ANNOTATE_DIAMOND_MAKEDB {
        errorStrategy = 'ignore'
    }
    withName: ANNOTATE_REPORT {
        errorStrategy = {
            if( task.exitStatus in [143, 137, 104, 134, 139, 1] ) {
                task.attempt <= 2 ? 'retry' : 'ignore'
            }
            else {
                'ignore'
            }
        }
        memory = { 72.GB * task.attempt * 2 }
        maxRetries = 2
    }
    withName: ANNOTATE_DIAMOND_BLASTX {
        errorStrategy = {
            if( task.exitStatus in [143, 137, 104, 134, 139, 1] ) {
                task.attempt <= 2 ? 'retry' : 'ignore'
            }
            else {
                'ignore'
            }
        }
        memory = { 72.GB * task.attempt * 2 }
        maxRetries = 2
        ext.args = '--very-sensitive'
    }
    withName: DIAMOND_BLASTX {
        errorStrategy = 'ignore'
        memory = { 72.GB * task.attempt * 2 }
        maxRetries = 0
        ext.args = '--very-sensitive'
    }
    withName: COUNT_READS {
        errorStrategy = 'ignore'
    }
    withName: MAP_PROT_ASSEMBLY {
        errorStrategy = 'ignore'
    }
    withName: TOP_HITS {
        ext.singularity_pull_docker_container = true
        errorStrategy = 'ignore'
    }
    withName: MAP_TAXID_ASSEMBLY {
        ext.singularity_pull_docker_container = true
        errorStrategy = 'ignore'
    }
    withName: ORGANISM_MERGE_REPORT {
        ext.singularity_pull_docker_container = true
        errorStrategy = 'ignore'
    }
    withName: FASTP {
        ext.args = ''
        memory = { 36.GB * task.attempt * 2 } // Starts with GB and doubles each attempt
        maxRetries = 2
        errorStrategy = { task.exitStatus in [143, 137, 104, 134, 139, 1] ? 'retry' : 'ignore' }
    }
    withName: FEATURES_DOWNLOAD {
        errorStrategy = 'ignore'
    }
    withName: DOWNLOAD_TAXDUMP {
        errorStrategy = 'ignore'
    }
    withName: FEATURES_TO_BED  {
        errorStrategy = 'ignore'
    }
    withName: BEDTOOLS_GENOMECOVERAGE {
        errorStrategy = {
            if( task.exitStatus in [143, 137, 104, 134, 139, 1] ) {
                task.attempt <= 2 ? 'retry' : 'ignore'
            }
            else {
                'ignore'
            }
        }
        memory = { 36.GB * task.attempt * 2 }
        maxRetries = 3
    }
    withName: BEDTOOLS_COVERAGE  {
        errorStrategy = {
            if( task.exitStatus in [143, 137, 104, 134, 139, 1] ) {
                task.attempt <= 2 ? 'retry' : 'ignore'
            }
            else {
                'ignore'
            }
        }
        memory = { 36.GB * task.attempt * 2 }
        maxRetries = 3
        publishDir = [path:{ "${params.outdir}/alignment" }, mode:'copy', saveAs:{ filename -> filename.equals('versions.yml') ? null : filename }]
    }
    withName: BOWTIE2_ALIGN {
        ext.args = ''
        maxRetries = 0
        errorStrategy = 'ignore'
        publishDir = [path:{ "${params.outdir}/alignment" }, mode:'copy', saveAs:{ filename -> filename.equals('versions.yml') ? null : filename }]
    }
    withName: HISAT2_ALIGN {
        maxRetries = 0
        errorStrategy = 'ignore'
        publishDir = [path:{ "${params.outdir}/alignment" }, mode:'copy', saveAs:{ filename -> filename.equals('versions.yml') ? null : filename }]
    }
    withName: BBMAP_BBNORM {
        maxRetries = 0
        errorStrategy = 'ignore'
    }
    withName: MICROBERT_PARSE {
        maxRetries = 0
        errorStrategy = 'ignore'
    }
    withName: MICROBERT_PREDICT {
        maxRetries = 0
        errorStrategy = 'ignore'
    }

    withName: 'MINIMAP2_ALIGN' {
        // Memory ladder: 40→56→72→88 GB across retries.
        // 40 GB floor accounts for the Fusion/S3 page-cache overhead (~reference size)
        // on top of minimap2's index.
        //
        // Strategy: --split-prefix is OFF by default (params.split_prefix=false) so the
        // reference is indexed as a SINGLE block. minimap2 writes an intermediate SAM
        // which is then sorted by samtools (decoupled, not piped).
        // -I/-K are NOT set automatically: when params.mmap2_I / mmap2_K are unset,
        // minimap2 uses its own defaults and manages memory itself. Override them only
        // if a specific run needs tuning.
        //
        // minimap2 simultaneously holds its index in RAM, exhausting the container
        // memory budget before alignment starts ("chunk pre-fetch failed: cannot
        // allocate memory").  Streaming on-demand is slower but doesn't OOM.
        maxRetries = 3
        errorStrategy = {
            task.attempt <= 3 ? 'retry' : 'ignore'
        }
        memory = { 40.GB + (16.GB * (task.attempt - 1)) }
        ext.args = ''
    }

    withName: 'FILTER_MINIMAP2' {
        // Same memory ladder and Fusion prefetch fix as MINIMAP2_ALIGN above.
        maxRetries = 3
        errorStrategy = {
            task.attempt <= 3 ? 'retry' : 'ignore'

        }
        memory = { 40.GB + (16.GB * (task.attempt - 1)) }
        ext.args = ''
    }
    withName: REMOVE_HOSTREADS {
        errorStrategy  = {
            task.attempt <= 3 ? 'retry' : 'ignore'
        }
        memory = { 40.GB + (16.GB * (task.attempt - 1)) }
        maxRetries  = 3
    }

    withName: SAMTOOLS_HIST_COVERAGE {
        ext.args = ' -w 100  '
        ext.prefix = { "${meta.id}.histogram" }
        publishDir = [path:{ "${params.outdir}/alignment" }, mode:'copy', saveAs:{ filename -> filename.equals('versions.yml') ? null : filename }]

    }
    withName: FILTERED_STATS {
        publishDir = [path:{ "${params.outdir}/alignment" }, mode:'copy', saveAs:{ filename -> filename.equals('versions.yml') ? null : filename }]
    }
    withName: FILTERED_STATS {
        errorStrategy = 'ignore'
    }
    withName: TAXPASTA_STANDARDISE {
        errorStrategy = 'ignore'
    }
    withName: METAPHLAN_METAPHLAN {
        errorStrategy = 'ignore'
    }

    withName: CREATE_COMPARISON_REPORT {
        ext.singularity_pull_docker_container = true
        errorStrategy = 'ignore'
        publishDir = [path:{ "${params.outdir}/report" }, mode:'copy', saveAs:{ filename -> filename.equals('versions.yml') ? null : filename }]
    }

    withName: 'FLYE' {
        ext.args =  "--meta "
        memory = { 72.GB * task.attempt * 2 } // Starts with GB and doubles each attempt
        errorStrategy = {
            if( task.exitStatus in [1,143,137,104,134,139] ) {
                task.attempt <= 2 ? 'retry' : 'ignore'
            }
            else {
                'ignore'
            }
        }
        maxRetries = 2
        publishDir = [
            [
                path: { "${params.outdir}/assembly/flye/meta" },
                mode: params.publish_dir_mode,
                pattern: '*.{fa.gz,gfa.gz}'
            ],
            [
                path: { "${params.outdir}/assembly/flye/meta/log" },
                mode: params.publish_dir_mode,
                pattern: '*.log'
            ]
        ]
    }




    withName: CUSTOM_DUMPSOFTWAREVERSIONS {
        publishDir = [
            path: { "${params.outdir}/pipeline_info" },
            mode: params.publish_dir_mode,
            pattern: '*_versions.yml'
        ]
    }

    // ── In-silico read simulation modules ──
    withName: MAKE_SIMULATED_SAMPLES {
        errorStrategy = 'ignore'
        publishDir = [
            path: { "${params.outdir}/simulation/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: INSILICOSEQ_SIMULATE {
        errorStrategy = 'ignore'
        ext.mode = params.iss_mode ?: 'kde'
        publishDir = [
            path: { "${params.outdir}/simulation/${meta.id}/iss" },
            mode: params.publish_dir_mode,
            pattern: '*.fastq.gz'
        ]
    }
    withName: PREPARE_NANOSIM_INPUTS {
        errorStrategy = 'ignore'
    }
    withName: NANOSIM_SIMULATE {
        errorStrategy = 'ignore'
        ext.nanosim_base = params.nanosim_base ?: 'training'
        publishDir = [
            path: { "${params.outdir}/simulation/${meta.id}/nanosim" },
            mode: params.publish_dir_mode,
            pattern: '*.fastq.gz'
        ]
    }

}
